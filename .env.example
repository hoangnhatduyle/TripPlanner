# Copy this to .env.local for local development (never commit .env.local)
# Add these same values to your Vercel project's Environment Variables.

# Found in: Neon Dashboard → your project → Connection Details → Connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/tripPlanner
USE_LOCAL_PG=true

# ── Local development (standard PostgreSQL) ────────────────────────────────────
# ── Auth ───────────────────────────────────────────────────────────────────────
# A long random secret used to sign JWTs — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── Optional features ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=